<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Stylized 'A' Scroll Icon -->
    <path
        android:pathData="M30,75 L54,30 L78,75 M40,65 L68,65"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="30"
                android:endX="78"
                android:endY="75"
                android:type="linear">
                <item android:offset="0" android:color="#6366F1" /> <!-- Indigo -->
                <item android:offset="1" android:color="#EC4899" /> <!-- Pink -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Scroll Detail -->
    <path
        android:pathData="M25,75 C25,80 30,82 35,80 L73,80 C78,82 83,80 83,75"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="25"
                android:startY="75"
                android:endX="83"
                android:endY="80"
                android:type="linear">
                <item android:offset="0" android:color="#EC4899" />
                <item android:offset="1" android:color="#8B5CF6" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
